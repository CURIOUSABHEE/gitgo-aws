
# ============================================
# LOCAL DEVELOPMENT ENVIRONMENT VARIABLES
# ============================================

# GitHub OAuth App Credentials
# Create a GitHub OAuth App at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# GitHub Personal Access Token (for repository sync pipeline)
# Create at: https://github.com/settings/tokens
# Required scopes: repo, read:org
GITHUB_TOKEN=your_github_personal_access_token_here

# LinkedIn OAuth App Credentials
# Create a LinkedIn OAuth App at: https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_random_secret_key_here
# Generate NEXTAUTH_SECRET with: openssl rand -base64 32

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/gitgo
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/gitgo

# Groq API Keys for AI-powered analysis (load distribution)
# Get your keys at: https://console.groq.com/keys
# Multiple keys help distribute API rate limits across requests
GROQ_API_KEY=your_groq_api_key_here
GROQ_API_KEY_1=your_groq_api_key_1_here
GROQ_API_KEY_2=your_groq_api_key_2_here
GROQ_API_KEY_3=your_groq_api_key_3_here
GROQ_API_KEY_ARCHI_1=your_groq_api_key_archi_1_here
GROQ_API_KEY_ARCHI_2=your_groq_api_key_archi_2_here
GROQ_API_KEY_FOR_OPEN_SOUCE_FINDING_1=your_groq_api_key_match_1_here
GROQ_API_KEY_FOR_OPEN_SOUCE_FINDING_2=your_groq_api_key_match_2_here
GROQ_API_KEY_FOR_OPEN_SOUCE_FINDING_3=your_groq_api_key_match_3_here

# Cron Job Secret (for scheduled repository sync)
# Generate with: openssl rand -base64 32
CRON_SECRET=your_secure_random_secret_here

# ============================================
# AWS DEPLOYMENT ENVIRONMENT VARIABLES
# (Only needed when deploying to AWS)
# ============================================

# Database Mode: "mongodb" for local, "dynamodb" for AWS
DATABASE_MODE=mongodb

# AWS Region (must match where your DynamoDB/S3/Bedrock are deployed)
GITGO_AWS_REGION=us-east-1

# Execution Mode: "local" for development, "lambda" for AWS Amplify
GITGO_EXECUTION_MODE=local

# S3 Bucket for Resume Storage (AWS only)
GITGO_S3_BUCKET_NAME=gitgo-resumes-bucket-users

# API Gateway URL (AWS only, optional)
API_GATEWAY_URL=https://your-api-gateway-url.execute-api.us-east-1.amazonaws.com
